{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/accessibility.input.json",
  "type": "object",
  "required": ["mode"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["crawl", "session"],
      "description": "crawl: score pages against WCAG criteria. session: return checklist for agent to enforce."
    },
    "level": {
      "type": "string",
      "enum": ["A", "AA", "AAA"],
      "default": "AA",
      "description": "WCAG conformance level to evaluate against"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["url", "html"],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL of the page being audited"
          },
          "html": {
            "type": "string",
            "description": "HTML content of the page"
          }
        }
      }
    },
    "locale": {
      "type": "string",
      "default": "en",
      "description": "BCP 47 locale code"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "crawl" } }
      },
      "then": {
        "required": ["pages"]
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "session" } }
      },
      "then": {
        "required": ["level"]
      }
    }
  ],
  "additionalProperties": false
}
