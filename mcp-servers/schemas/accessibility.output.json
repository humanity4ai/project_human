{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/accessibility.output.json",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["crawl", "session"]
    },
    "level": {
      "type": "string",
      "enum": ["A", "AA", "AAA"]
    },
    "ranking": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "aggregate_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "automated": { "type": "integer", "minimum": 0 },
          "manual": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "criteria": { "type": "array" },
          "heuristic": { "type": "boolean" }
        }
      }
    },
    "site_aggregate": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Average score across all pages"
    },
    "checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "level": { "type": "string", "enum": ["A", "AA", "AAA"] },
          "principle": { "type": "string", "enum": ["perceivable", "operable", "understandable", "robust"] },
          "requirement": { "type": "string" },
          "implementation": { "type": "string" }
        }
      }
    },
    "session_notice": {
      "type": "string"
    },
    "criteria_count": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "A": { "type": "integer" },
        "AA": { "type": "integer" },
        "AAA": { "type": "integer" }
      }
    },
    "summary": {
      "type": "string"
    },
    "heuristic": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
